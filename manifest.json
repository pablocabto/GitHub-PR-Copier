{
  "manifest_version": 3,
  "name": "GitHub PR Copier",
  "version": "1.0.1",
  "description": "Copia título, URL y estadísticas de una Pull Request de GitHub.",
  "permissions": ["activeTab", "scripting", "clipboardWrite"],
  "host_permissions": ["https://github.com/*/*/pull/*"],
  "action": {
    "default_title": "Copiar resumen de la PR"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
